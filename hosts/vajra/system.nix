# Host: vajra - NixOS system configuration
{
  pkgs,
  vars,
  ...
}:
{
  # TODO: Import hardware-configuration.nix from your NixOS install
  # imports = [
  #   ./hardware-configuration.nix
  # ];

  users.users.${vars.os_user} = {
    isNormalUser = true;
    createHome = true;
    home = "/home/${vars.os_user}";
    extraGroups = [
      "wheel"
      "networkmanager"
      "video"
      "audio"
    ];
    shell = pkgs.nushell;
  };

  environment.systemPackages = with pkgs; [
    home-manager
  ];

  # Enable networking
  networking = {
    hostName = "vajra";
    networkmanager.enable = true;
  };

  # Boot loader - adjust for your system
  boot.loader.systemd-boot.enable = true;
  boot.loader.efi.canTouchEfiVariables = true;

  # TODO: Replace with your actual hardware-configuration.nix
  # Generated by nixos-generate-config on your vajra laptop.
  # For now, a minimal placeholder to pass evaluation:
  fileSystems."/" = {
    device = "/dev/disk/by-label/nixos";
    fsType = "ext4";
  };

  # Enable nix-ld for running unpatched binaries
  programs.nix-ld.enable = true;

  system.stateVersion = "24.11";
}
